# .env.example
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA faça commit do .env com valores reais!

# ---------------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin_password_aqui
AIRFLOW_ADMIN_EMAIL=admin@company.com
AIRFLOW_WEBSERVER_PORT=8080

# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=SUA_FERNET_KEY_AQUI

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
WEBSERVER_SECRET_KEY=SUA_WEBSERVER_SECRET_KEY_AQUI

# ---------------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=postgres_password_aqui

# ---------------------------------------------------------------------------
# SharePoint / Azure AD
# (Crie um App Registration no Azure Portal com permissões Sites.Read.All)
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=seu-tenant-id
AZURE_CLIENT_ID=seu-client-id
AZURE_CLIENT_SECRET=seu-client-secret
SHAREPOINT_SITE_URL=https://seudominio.sharepoint.com/sites/seu-site

# ---------------------------------------------------------------------------
# GCP / GCS
# (Crie uma Service Account com permissão roles/storage.objectCreator)
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=seu-projeto-gcp
GCS_DATALAKE_BUCKET=nome-do-seu-bucket
GCS_DESTINATION_PREFIX=raw/sharepoint

# ---------------------------------------------------------------------------
# SMTP (para alertas por e-mail)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app-gmail
ALERT_EMAIL=data-team@company.com

# ---------------------------------------------------------------------------
# Flower (monitoramento Celery) — opcional
# ---------------------------------------------------------------------------
FLOWER_PORT=5555
